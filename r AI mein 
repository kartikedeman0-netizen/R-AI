<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>R AI — Earn Smarter</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<style>
:root{--bg:#F7F6F2;--surface:#FFFFFF;--surface2:#F0EFE9;--border:#E2E0D8;--text:#1A1916;--text2:#6B6860;--accent:#1A6B4A;--accent-light:#E8F5EF;--gold:#C8A84B;--gold-light:#FDF6E3;--red:#C0392B;--radius:16px}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh;display:flex;flex-direction:column}
.topbar{display:flex;align-items:center;justify-content:space-between;padding:12px 20px;background:var(--surface);border-bottom:1px solid var(--border);position:sticky;top:0;z-index:100}
.logo{display:flex;align-items:center;gap:10px}
.logo-mark{width:34px;height:34px;background:var(--text);border-radius:9px;display:flex;align-items:center;justify-content:center;font-family:'Syne',sans-serif;font-weight:800;font-size:14px;color:white}
.logo-text{font-family:'Syne',sans-serif;font-weight:700;font-size:17px;letter-spacing:-0.5px}
.logo-sub{font-size:10px;color:var(--text2);margin-top:1px}
.topbar-right{display:flex;gap:8px}
.mode-pill{padding:6px 14px;border-radius:100px;font-size:12px;font-weight:500;cursor:pointer;border:1.5px solid var(--border);background:transparent;color:var(--text2);transition:all 0.2s;font-family:'DM Sans',sans-serif}
.mode-pill.active,.mode-pill:hover{background:var(--text);color:white;border-color:var(--text)}
.main{display:flex;flex:1;overflow:hidden;height:calc(100vh - 61px)}
.sidebar{width:255px;background:var(--surface);border-right:1px solid var(--border);display:flex;flex-direction:column;overflow:hidden}
.sidebar-head{padding:14px}
.new-chat-btn{width:100%;padding:10px 14px;background:var(--text);color:white;border:none;border-radius:10px;font-family:'DM Sans',sans-serif;font-size:13px;font-weight:500;cursor:pointer;display:flex;align-items:center;gap:8px;transition:opacity 0.2s}
.new-chat-btn:hover{opacity:0.85}
.sidebar-section{padding:10px 14px 4px;font-size:10px;font-weight:600;color:var(--text2);letter-spacing:1px;text-transform:uppercase}
.chat-list{flex:1;overflow-y:auto;padding:4px 8px}
.date-label{padding:8px 8px 4px;font-size:10px;font-weight:600;color:var(--text2);letter-spacing:0.5px}
.chat-item{padding:9px 10px;border-radius:8px;cursor:pointer;font-size:13px;color:var(--text2);transition:all 0.15s;display:flex;align-items:flex-start;gap:8px;margin-bottom:2px}
.chat-item:hover,.chat-item.active{background:var(--surface2);color:var(--text)}
.chat-item-title{white-space:nowrap;overflow:hidden;text-overflow:ellipsis;font-size:13px}
.chat-item-time{font-size:10px;color:var(--text2);margin-top:2px}
.mode-btns{padding:12px;border-top:1px solid var(--border)}
.mode-btns-title{font-size:10px;color:var(--text2);font-weight:600;letter-spacing:1px;text-transform:uppercase;margin-bottom:8px}
.mode-btn{width:100%;padding:8px 10px;border-radius:8px;border:1.5px solid var(--border);background:transparent;font-family:'DM Sans',sans-serif;font-size:12px;font-weight:500;cursor:pointer;text-align:left;color:var(--text);transition:all 0.15s;display:flex;align-items:center;gap:8px;margin-bottom:4px}
.mode-btn:hover{background:var(--surface2)}
.mode-btn.active-mode{background:var(--accent-light);border-color:var(--accent);color:var(--accent)}
.chat-area{flex:1;display:flex;flex-direction:column;overflow:hidden}
.welcome-screen{flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:32px 24px;gap:28px;overflow-y:auto}
.welcome-badge{display:inline-flex;align-items:center;gap:6px;padding:6px 14px;background:var(--gold-light);border:1px solid var(--gold);border-radius:100px;font-size:12px;font-weight:500;color:#8B6914;margin-bottom:16px}
.welcome-title{font-family:'Syne',sans-serif;font-size:36px;font-weight:800;line-height:1.1;letter-spacing:-1.5px;margin-bottom:12px;text-align:center}
.welcome-title span{background:linear-gradient(135deg,var(--accent) 0%,var(--gold) 100%);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.welcome-sub{font-size:14px;color:var(--text2);line-height:1.6;text-align:center}
.earn-cards{display:grid;grid-template-columns:repeat(3,1fr);gap:10px;width:100%;max-width:680px}
.earn-card{background:var(--surface);border:1.5px solid var(--border);border-radius:14px;padding:16px;cursor:pointer;transition:all 0.2s;position:relative;overflow:hidden}
.earn-card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;opacity:0;transition:opacity 0.2s}
.earn-card.freelance::before{background:var(--accent)}
.earn-card.trading::before{background:var(--gold)}
.earn-card.social::before{background:#1A4A8A}
.earn-card:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(26,25,22,0.1)}
.earn-card:hover::before{opacity:1}
.card-icon{font-size:24px;margin-bottom:10px}
.card-title{font-family:'Syne',sans-serif;font-size:13px;font-weight:700;margin-bottom:4px}
.card-desc{font-size:11px;color:var(--text2);line-height:1.5}
.chips{display:flex;flex-wrap:wrap;gap:8px;max-width:680px;justify-content:center}
.chip{padding:7px 14px;background:var(--surface);border:1.5px solid var(--border);border-radius:100px;font-size:12px;cursor:pointer;transition:all 0.15s;color:var(--text)}
.chip:hover{background:var(--text);color:white;border-color:var(--text)}
.messages-container{flex:1;overflow-y:auto;padding:20px;display:none;flex-direction:column;gap:18px}
.messages-container.visible{display:flex}
.message{display:flex;gap:10px;max-width:820px;animation:fadeUp 0.3s ease}
@keyframes fadeUp{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
.message.user{flex-direction:row-reverse;align-self:flex-end}
.avatar{width:32px;height:32px;border-radius:9px;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
.avatar.ai{background:var(--text);color:white;font-family:'Syne',sans-serif;font-weight:800;font-size:11px}
.avatar.user-av{background:var(--accent-light);border:1.5px solid var(--accent);font-size:14px}
.bubble{padding:12px 16px;border-radius:14px;font-size:14px;line-height:1.65;max-width:520px}
.message.ai .bubble{background:var(--surface);border:1.5px solid var(--border);border-top-left-radius:4px}
.message.user .bubble{background:var(--text);color:white;border-top-right-radius:4px}
.bubble-actions{display:flex;gap:6px;margin-top:8px;flex-wrap:wrap}
.bubble-btn{padding:4px 10px;border-radius:100px;border:1.5px solid var(--border);background:transparent;font-family:'DM Sans',sans-serif;font-size:11px;cursor:pointer;color:var(--text2);transition:all 0.15s}
.bubble-btn:hover{background:var(--surface2);color:var(--text)}
.bubble-btn.speaking{color:var(--accent);border-color:var(--accent)}
.typing-indicator{display:flex;gap:5px;padding:12px 16px;background:var(--surface);border:1.5px solid var(--border);border-radius:14px;border-top-left-radius:4px;width:fit-content}
.dot{width:6px;height:6px;background:var(--text2);border-radius:50%;animation:typing 1.2s ease infinite}
.dot:nth-child(2){animation-delay:0.2s}
.dot:nth-child(3){animation-delay:0.4s}
@keyframes typing{0%,60%,100%{transform:translateY(0);opacity:0.4}30%{transform:translateY(-4px);opacity:1}}
.input-area{padding:14px 20px 18px;background:var(--surface);border-top:1px solid var(--border)}
.input-wrapper{max-width:820px;margin:0 auto}
.mode-bar{display:none;align-items:center;gap:8px;margin-bottom:10px}
.mode-bar.visible{display:flex}
.mode-indicator{display:flex;align-items:center;gap:6px;padding:4px 12px;border-radius:100px;font-size:12px;font-weight:500;background:var(--accent-light);color:var(--accent)}
.mode-clear{background:none;border:none;cursor:pointer;color:var(--text2);font-size:15px}
.input-box{display:flex;align-items:flex-end;gap:8px;background:var(--bg);border:1.5px solid var(--border);border-radius:14px;padding:10px 12px;transition:border-color 0.2s}
.input-box:focus-within{border-color:var(--text)}
textarea{flex:1;background:transparent;border:none;outline:none;font-family:'DM Sans',sans-serif;font-size:14px;color:var(--text);resize:none;max-height:120px;line-height:1.5;padding:2px 0}
textarea::placeholder{color:var(--text2)}
.icon-btn{width:34px;height:34px;border-radius:9px;border:none;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;transition:all 0.15s;background:transparent}
.icon-btn:hover{background:var(--border)}
.mic-btn{color:var(--text2)}
.mic-btn.recording{background:#FFE5E5;color:var(--red);animation:pulse 1s ease infinite}
@keyframes pulse{0%,100%{transform:scale(1)}50%{transform:scale(1.08)}}
.send-btn{width:34px;height:34px;border-radius:9px;border:none;background:var(--text);color:white;cursor:pointer;display:flex;align-items:center;justify-content:center;font-size:16px;transition:opacity 0.15s}
.send-btn:hover{opacity:0.85}
.input-hint{font-size:11px;color:var(--text2);margin-top:8px;text-align:center}
.voice-overlay{display:none;position:fixed;inset:0;background:rgba(15,15,15,0.88);backdrop-filter:blur(14px);z-index:300;align-items:center;justify-content:center;flex-direction:column;gap:20px}
.voice-overlay.active{display:flex}
.voice-orb-wrap{position:relative;width:140px;height:140px;display:flex;align-items:center;justify-content:center}
.voice-ring{position:absolute;inset:0;border-radius:50%;border:2px solid rgba(255,255,255,0.15);animation:ringPulse 2s ease infinite}
.voice-ring:nth-child(2){animation-delay:0.5s;inset:-14px}
.voice-ring:nth-child(3){animation-delay:1s;inset:-28px}
@keyframes ringPulse{0%,100%{opacity:0.3}50%{opacity:0.08}}
.voice-orb{width:100px;height:100px;border-radius:50%;background:white;display:flex;align-items:center;justify-content:center;font-size:40px;position:relative;z-index:1}
.voice-status{color:white;font-family:'Syne',sans-serif;font-size:20px;font-weight:700;letter-spacing:-0.5px}
.voice-transcript{color:rgba(255,255,255,0.5);font-size:13px;max-width:300px;text-align:center;min-height:20px}
.voice-stop{padding:12px 28px;background:white;color:#1A1916;border:none;border-radius:100px;font-family:'DM Sans',sans-serif;font-size:14px;font-weight:500;cursor:pointer}
.api-notice{background:var(--gold-light);border:1px solid var(--gold);border-radius:10px;padding:10px 14px;font-size:12px;color:#8B6914;margin-bottom:12px}
.api-notice a{color:var(--accent);font-weight:500;text-decoration:none}
.api-row{display:flex;gap:8px;margin-top:6px}
.api-row input{flex:1;padding:6px 10px;border:1.5px solid var(--gold);border-radius:8px;font-family:'DM Sans',sans-serif;font-size:12px;background:white;color:var(--text);outline:none}
.api-row button{padding:6px 14px;background:var(--text);color:white;border:none;border-radius:8px;font-family:'DM Sans',sans-serif;font-size:12px;cursor:pointer}
::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:4px}
@media(max-width:600px){.sidebar{display:none}.earn-cards{grid-template-columns:1fr}.welcome-title{font-size:28px}.topbar-right{display:none}}
</style>
</head>
<body>

<div class="topbar">
  <div class="logo">
    <div class="logo-mark">R</div>
    <div>
      <div class="logo-text">R AI</div>
      <div class="logo-sub">Earn Smarter — Every Field</div>
    </div>
  </div>
  <div class="topbar-right">
    <button class="mode-pill active" onclick="setTopMode('general',this)">General</button>
    <button class="mode-pill" onclick="setTopMode('freelance',this)">💼 Freelance</button>
    <button class="mode-pill" onclick="setTopMode('trading',this)">📈 Trading</button>
    <button class="mode-pill" onclick="setTopMode('social',this)">📱 Social</button>
  </div>
</div>

<div class="main">
  <div class="sidebar">
    <div class="sidebar-head">
      <button class="new-chat-btn" onclick="newChat()">✦ New Chat</button>
    </div>
    <div class="sidebar-section">Chat History</div>
    <div class="chat-list" id="chatList"></div>
    <div class="mode-btns">
      <div class="mode-btns-title">Earn Modes</div>
      <button class="mode-btn" id="btn-freelance" onclick="activateMode('freelance')">💼 Freelancing</button>
      <button class="mode-btn" id="btn-trading" onclick="activateMode('trading')">📈 Stock & Crypto</button>
      <button class="mode-btn" id="btn-social" onclick="activateMode('social')">📱 Social Media</button>
    </div>
  </div>

  <div class="chat-area">
    <div class="welcome-screen" id="welcomeScreen">
      <div>
        <div class="welcome-badge">✦ Your AI Earning Partner</div>
        <h1 class="welcome-title">Har Field Mein<br><span>Earn Karo</span></h1>
        <p class="welcome-sub">Freelancing se trading tak — R AI tumhara personal money-making advisor hai.</p>
      </div>
      <div class="earn-cards">
        <div class="earn-card freelance" onclick="activateMode('freelance');sendSug('Freelancing kaise shuru karun?')">
          <div class="card-icon">💼</div>
          <div class="card-title">Freelancing</div>
          <div class="card-desc">Clients dhundho, projects lo, paise kamao</div>
        </div>
        <div class="earn-card trading" onclick="activateMode('trading');sendSug('Stocks mein invest kaise karein?')">
          <div class="card-icon">📈</div>
          <div class="card-title">Stock & Crypto</div>
          <div class="card-desc">Market analysis, investment ideas</div>
        </div>
        <div class="earn-card social" onclick="activateMode('social');sendSug('Social media se paise kaise kamaun?')">
          <div class="card-icon">📱</div>
          <div class="card-title">Social Media</div>
          <div class="card-desc">Content strategy, monetization</div>
        </div>
      </div>
      <div class="chips">
        <div class="chip" onclick="sendSug('Ghar baithe paise kamane ke tarike batao')">🏠 Ghar se earn</div>
        <div class="chip" onclick="sendSug('Side income ideas for students')">💡 Side income</div>
        <div class="chip" onclick="sendSug('Instagram se paise kaise kamaye?')">📸 Instagram earn</div>
        <div class="chip" onclick="sendSug('Crypto investment guide for beginners')">₿ Crypto guide</div>
      </div>
    </div>

    <div class="messages-container" id="msgContainer"></div>

    <div class="input-area">
      <div class="input-wrapper">
        <div class="api-notice" id="apiNotice">
          ⚡ Real AI ke liye Groq key daalo — Free: <a href="https://console.groq.com" target="_blank">console.groq.com</a>
          <div class="api-row">
            <input type="password" id="apiKeyInput" placeholder="gsk_... Groq key">
            <button onclick="saveKey()">Save</button>
          </div>
        </div>
        <div class="mode-bar" id="modeBar">
          <div class="mode-indicator" id="modeIndicator"></div>
          <button class="mode-clear" onclick="clearMode()">✕</button>
        </div>
        <div class="input-box">
          <textarea id="msgInput" placeholder="Kuch bhi pucho ya mic dabao..." rows="1" onkeydown="handleKey(event)" oninput="autoResize(this)"></textarea>
          <div style="display:flex;gap:6px;flex-shrink:0">
            <button class="icon-btn mic-btn" id="micBtn" onclick="toggleVoice()">🎙️</button>
            <button class="send-btn" onclick="sendMsg()">↑</button>
          </div>
        </div>
        <div class="input-hint">R AI — Financial info sirf educational hai</div>
      </div>
    </div>
  </div>
</div>

<div class="voice-overlay" id="voiceOverlay">
  <div class="voice-orb-wrap">
    <div class="voice-ring"></div>
    <div class="voice-ring"></div>
    <div class="voice-ring"></div>
    <div class="voice-orb">🎙️</div>
  </div>
  <div class="voice-status" id="voiceStatus">Sun raha hoon...</div>
  <div class="voice-transcript" id="voiceTranscript">Bolo — R AI sun raha hai</div>
  <button class="voice-stop" onclick="stopVoice()">⏹ Band Karo</button>
</div>

<script>
let groqKey=localStorage.getItem('r_ai_key')||'';
let currentMode='general';
let chatHistory=[];
let currentChatId='chat_'+Date.now();
let isRecording=false;
let recognition=null;
let synth=window.speechSynthesis;
let speakingUtt=null;
let isVoiceMode=false;

if(groqKey) document.getElementById('apiNotice').style.display='none';
loadChatList();

// ======= API KEY =======
function saveKey(){
  const k=document.getElementById('apiKeyInput').value.trim();
  if(k){groqKey=k;localStorage.setItem('r_ai_key',k);document.getElementById('apiNotice').style.display='none';}
}

// ======= MODES =======
const modeData={
  freelance:{icon:'💼',label:'Freelancing Mode',system:'You are R AI, a professional earning advisor focused on freelancing. Help with finding clients, proposals, pricing, portfolios for writing/design/coding, Upwork/Fiverr. Respond in Hinglish. Be direct, practical, action-oriented. Always focus on HOW to earn money.'},
  trading:{icon:'📈',label:'Trading Mode',system:'You are R AI, a financial markets educator. Provide educational info about stocks, crypto, market analysis, risk management, Indian markets NSE/BSE. Always add disclaimer this is educational not financial advice. Respond in Hinglish.'},
  social:{icon:'📱',label:'Social Media Mode',system:'You are R AI, a social media monetization expert. Help with Instagram/YouTube/LinkedIn growth, content strategies, brand deals, affiliate marketing, digital products. Respond in Hinglish. Be creative and trend-aware.'},
  general:{icon:'✦',label:'R AI',system:'You are R AI, a smart earning advisor who helps people make money across all fields — freelancing, trading, social media, business, passive income. Be practical and motivating. Respond in Hinglish. Always focus on real actionable ways to earn money.'}
};

function activateMode(mode){
  currentMode=mode;
  document.querySelectorAll('.mode-btn').forEach(b=>b.classList.remove('active-mode'));
  const btn=document.getElementById('btn-'+mode);
  if(btn) btn.classList.add('active-mode');
  const bar=document.getElementById('modeBar'),ind=document.getElementById('modeIndicator');
  if(mode!=='general'){bar.classList.add('visible');ind.textContent=modeData[mode].icon+' '+modeData[mode].label;}
  else bar.classList.remove('visible');
}

function setTopMode(mode,el){
  document.querySelectorAll('.mode-pill').forEach(p=>p.classList.remove('active'));
  el.classList.add('active');
  activateMode(mode);
}

function clearMode(){
  currentMode='general';
  document.getElementById('modeBar').classList.remove('visible');
  document.querySelectorAll('.mode-btn').forEach(b=>b.classList.remove('active-mode'));
  document.querySelector('.mode-pill').classList.add('active');
}

// ======= CHAT HISTORY =======
function getAllChats(){return JSON.parse(localStorage.getItem('r_ai_chats')||'[]');}
function saveAllChats(c){localStorage.setItem('r_ai_chats',JSON.stringify(c));}

function saveCurrent(){
  if(chatHistory.length===0) return;
  const chats=getAllChats().filter(c=>c.id!==currentChatId);
  const first=chatHistory.find(m=>m.role==='user');
  chats.unshift({id:currentChatId,title:first?first.content.substring(0,40):'Conversation',timestamp:Date.now(),mode:currentMode,history:[...chatHistory]});
  saveAllChats(chats.slice(0,60));
  loadChatList();
}

function newChat(){
  saveCurrent();
  chatHistory=[];currentChatId='chat_'+Date.now();
  document.getElementById('msgContainer').innerHTML='';
  document.getElementById('msgContainer').classList.remove('visible');
  document.getElementById('welcomeScreen').style.display='flex';
  loadChatList();
}

function loadChatList(){
  const chats=getAllChats();
  const list=document.getElementById('chatList');
  if(chats.length===0){list.innerHTML='<div style="padding:16px;font-size:12px;color:var(--text2);text-align:center">Koi chat nahi abhi</div>';return;}
  const groups=groupByDate(chats);
  list.innerHTML=groups.map(g=>`<div class="date-label">${g.label}</div>`+g.items.map(c=>`<div class="chat-item${c.id===currentChatId?' active':''}" onclick="loadChat('${c.id}')"><div style="flex-shrink:0">💬</div><div style="flex:1;min-width:0"><div class="chat-item-title">${c.title}</div><div class="chat-item-time">${formatTime(c.timestamp)}</div></div></div>`).join('')).join('');
}

function groupByDate(chats){
  const now=new Date(),today=new Date(now.getFullYear(),now.getMonth(),now.getDate());
  const yesterday=new Date(today-86400000);
  const groups=[],map={};
  chats.forEach(c=>{
    const d=new Date(c.timestamp),chatDay=new Date(d.getFullYear(),d.getMonth(),d.getDate());
    let label;
    if(chatDay>=today) label='Aaj';
    else if(chatDay>=yesterday) label='Kal';
    else if(now-chatDay<7*86400000) label=d.toLocaleDateString('hi-IN',{weekday:'long'});
    else label=d.toLocaleDateString('en-IN',{day:'numeric',month:'long',year:'numeric'});
    if(!map[label]){map[label]=[];groups.push({label,items:map[label]});}
    map[label].push(c);
  });
  return groups;
}

function formatTime(ts){return new Date(ts).toLocaleTimeString('en-IN',{hour:'2-digit',minute:'2-digit',hour12:true});}

function loadChat(id){
  saveCurrent();
  const chat=getAllChats().find(c=>c.id===id);
  if(!chat) return;
  chatHistory=[...chat.history];currentChatId=id;currentMode=chat.mode||'general';
  document.getElementById('msgContainer').innerHTML='';
  document.getElementById('welcomeScreen').style.display='none';
  document.getElementById('msgContainer').classList.add('visible');
  chatHistory.forEach(m=>{if(m.role==='user')appendMsg('user',m.content);else if(m.role==='assistant')appendMsg('ai',m.content);});
  loadChatList();
}

// ======= SEND =======
async function sendMsg(){
  const input=document.getElementById('msgInput'),text=input.value.trim();
  if(!text) return;
  input.value='';autoResize(input);
  document.getElementById('welcomeScreen').style.display='none';
  document.getElementById('msgContainer').classList.add('visible');
  appendMsg('user',text);chatHistory.push({role:'user',content:text});
  const tid=showTyping();
  try{
    const reply=groqKey?await callGroq(text):getFallback(currentMode);
    removeTyping(tid);appendMsg('ai',reply);
    chatHistory.push({role:'assistant',content:reply});
    saveCurrent();
    if(isVoiceMode) autoSpeak(reply);
  }catch(e){removeTyping(tid);appendMsg('ai','⚠️ Error aaya. Dobara try karo.');}
}

async function callGroq(msg){
  const mode=modeData[currentMode]||modeData.general;
  const res=await fetch('https://api.groq.com/openai/v1/chat/completions',{method:'POST',headers:{'Content-Type':'application/json','Authorization':'Bearer '+groqKey},body:JSON.stringify({model:'llama-3.3-70b-versatile',messages:[{role:'system',content:mode.system},...chatHistory.slice(-8),{role:'user',content:msg}],max_tokens:700,temperature:0.7})});
  if(!res.ok) throw new Error('err');
  return (await res.json()).choices[0].message.content;
}

function getFallback(mode){
  const r={freelance:`**Freelancing shuru karne ke steps:**\n\n1. Skill choose karo — Writing, Design, Coding\n2. Portfolio banao — 3-5 sample projects\n3. Upwork + Fiverr pe profile banao\n4. Pehle reviews ke liye kam rate\n5. Dhire rate badhao\n\n💡 Groq API key daalo real answers ke liye!`,trading:`**Stock Market Guide:**\n\n1. Zerodha ya Groww pe demat account\n2. SIP se shuru — ₹500/month bhi chalega\n3. Nifty 50 Index Fund — sabse safe\n4. Kabhi borrow karke invest mat karo\n\n⚠️ Groq key daalo real answers ke liye!`,social:`**Social Media Monetization:**\n\n1. Niche choose karo — Finance, Fitness, Food\n2. Consistent content — weekly 3-4 posts\n3. 10K followers ke baad brand deals\n4. Affiliate links se passive income\n\n💡 Groq key daalo detailed guidance ke liye!`,general:`**Paise kamane ke top tarike:**\n\n💼 Freelancing — ₹15K-1.5L/month\n📈 Investing — Long-term wealth\n📱 Content Creation — YouTube, Instagram\n🛒 Reselling — Meesho, Amazon\n\nGroq key daalo real AI answers ke liye! 🎯`};
  return r[mode]||r.general;
}

function sendSug(text){document.getElementById('msgInput').value=text;sendMsg();}

function appendMsg(role,text){
  const c=document.getElementById('msgContainer'),id='msg_'+Date.now();
  const fmt=text.replace(/\*\*(.*?)\*\*/g,'<strong>$1</strong>').replace(/\n\n/g,'<br><br>').replace(/\n/g,'<br>');
  const safe=text.replace(/\\/g,'\\\\').replace(/`/g,'\\`').replace(/'/g,"\\'").replace(/"/g,'\\"');
  if(role==='ai'){
    c.innerHTML+=`<div class="message ai" id="${id}"><div class="avatar ai">R</div><div><div class="bubble">${fmt}</div><div class="bubble-actions"><button class="bubble-btn" id="spk_${id}" onclick="speakMsg('${id}','${safe}')">🔊 Suno</button><button class="bubble-btn" onclick="copyMsg('${safe}')">📋 Copy</button></div></div></div>`;
  }else{
    c.innerHTML+=`<div class="message user"><div class="avatar user-av">👤</div><div class="bubble">${fmt}</div></div>`;
  }
  c.scrollTop=c.scrollHeight;
}

function showTyping(){const c=document.getElementById('msgContainer'),id='typ_'+Date.now();c.innerHTML+=`<div class="message ai" id="${id}"><div class="avatar ai">R</div><div class="typing-indicator"><div class="dot"></div><div class="dot"></div><div class="dot"></div></div></div>`;c.scrollTop=c.scrollHeight;return id;}
function removeTyping(id){const el=document.getElementById(id);if(el)el.remove();}

// ======= JARVIS VOICE =======
function getJarvisVoice(){
  const v=synth.getVoices();
  return v.find(x=>x.name.includes('Google UK English Male'))||v.find(x=>x.name.includes('Microsoft George'))||v.find(x=>x.name.includes('Male')&&x.lang.startsWith('en'))||v.find(x=>x.lang==='en-GB')||v.find(x=>x.lang.startsWith('en'))||v[0];
}

function speakMsg(msgId,text){
  const btn=document.getElementById('spk_'+msgId);
  if(speakingUtt){synth.cancel();speakingUtt=null;document.querySelectorAll('.bubble-btn').forEach(b=>{if(b.id?.startsWith('spk_')){b.classList.remove('speaking');b.textContent='🔊 Suno';}});return;}
  const clean=text.replace(/\*\*/g,'').replace(/#{1,3}/g,'').replace(/<[^>]+>/g,'');
  const utt=new SpeechSynthesisUtterance(clean);
  const voice=getJarvisVoice();if(voice)utt.voice=voice;
  utt.rate=0.88;utt.pitch=0.9;utt.volume=1;
  utt.onstart=()=>{if(btn){btn.classList.add('speaking');btn.textContent='⏹ Roko';}speakingUtt=utt;};
  utt.onend=()=>{if(btn){btn.classList.remove('speaking');btn.textContent='🔊 Suno';}speakingUtt=null;};
  synth.speak(utt);
}

function autoSpeak(text){
  const clean=text.replace(/\*\*/g,'').replace(/#{1,3}/g,'').replace(/<[^>]+>/g,'');
  const utt=new SpeechSynthesisUtterance(clean);
  const voice=getJarvisVoice();if(voice)utt.voice=voice;
  utt.rate=0.88;utt.pitch=0.9;
  utt.onend=()=>{speakingUtt=null;};
  speakingUtt=utt;synth.speak(utt);
}

function copyMsg(text){navigator.clipboard.writeText(text).then(()=>alert('Copied!'));}

// ======= VOICE INPUT =======
function toggleVoice(){
  if(isRecording){stopVoice();return;}
  const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
  if(!SR){alert('Voice sirf Chrome mein kaam karta hai!');return;}
  recognition=new SR();
  recognition.lang='hi-IN';recognition.continuous=false;recognition.interimResults=true;
  recognition.onstart=()=>{isRecording=true;isVoiceMode=true;document.getElementById('micBtn').classList.add('recording');document.getElementById('voiceOverlay').classList.add('active');document.getElementById('voiceStatus').textContent='Sun raha hoon...';document.getElementById('voiceTranscript').textContent='';};
  recognition.onresult=(e)=>{
    let final='',interim='';
    for(let i=e.resultIndex;i<e.results.length;i++){if(e.results[i].isFinal)final+=e.results[i][0].transcript;else interim+=e.results[i][0].transcript;}
    document.getElementById('voiceTranscript').textContent=final||interim;
    if(final){document.getElementById('voiceStatus').textContent='Samajh gaya!';document.getElementById('msgInput').value=final;stopVoice();setTimeout(()=>sendMsg(),400);}
  };
  recognition.onerror=(e)=>{document.getElementById('voiceStatus').textContent='Error: '+e.error;setTimeout(stopVoice,1500);};
  recognition.onend=()=>{if(isRecording)stopVoice();};
  recognition.start();
}

function stopVoice(){isRecording=false;document.getElementById('micBtn').classList.remove('recording');document.getElementById('voiceOverlay').classList.remove('active');if(recognition){try{recognition.stop();}catch(e){}recognition=null;}}

function handleKey(e){if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMsg();}}
function autoResize(el){el.style.height='auto';el.style.height=Math.min(el.scrollHeight,120)+'px';}
if(synth){synth.getVoices();synth.addEventListener('voiceschanged',()=>synth.getVoices());}
</script>
